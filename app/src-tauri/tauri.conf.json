{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeVoice",
  "version": "0.1.0",
  "identifier": "dev.vibevoice.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VibeVoice",
        "width": 980,
        "height": 680,
        "minWidth": 760,
        "minHeight": 520,
        "alwaysOnTop": false
      },
      {
        "label": "pill",
        "title": "VibeVoice Pill",
        "width": 352,
        "height": 76,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "nsis"],
    "resources": [
      "../../scripts/install-engine.sh",
      "../../scripts/install-fedora.sh",
      "../../scripts/install-windows.ps1",
      "../../scripts/check-system.sh",
      "../../scripts/check-windows.ps1"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
