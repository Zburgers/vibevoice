{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeVoice",
  "version": "0.1.0",
  "identifier": "dev.vibevoice.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeVoice",
        "width": 980,
        "height": 680,
        "minWidth": 760,
        "minHeight": 520,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": []
  }
}
