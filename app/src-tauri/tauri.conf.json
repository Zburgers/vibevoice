{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeVoice",
  "version": "0.2.3",
  "identifier": "dev.zburgers.vibevoice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VibeVoice",
        "width": 980,
        "height": 680,
        "minWidth": 560,
        "minHeight": 520,
        "alwaysOnTop": false,
        "decorations": false
      },
      {
        "label": "pill",
        "title": "VibeVoice Pill",
        "width": 352,
        "height": 76,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi", "deb", "rpm", "appimage", "dmg", "app"],
    "publisher": "Zburgers",
    "category": "Productivity",
    "shortDescription": "Local-first desktop voice input for developers",
    "longDescription": "VibeVoice records microphone audio, transcribes it locally with whisper.cpp, cleans developer terms, and copies or pastes the result into the focused app.",
    "resources": [
      "../../scripts/install-engine.sh",
      "../../scripts/install-fedora.sh",
      "../../scripts/install-app.sh",
      "../../scripts/install-app.ps1",
      "../../scripts/uninstall-app.sh",
      "../../scripts/uninstall-app.ps1",
      "../../scripts/install-windows.ps1",
      "../../scripts/check-system.sh",
      "../../scripts/check-windows.ps1"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": ["en-US"]
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNEM4RjQxOTM5OEFCOEEKUldTS3E1aVRRWTlNZ1Y2MjBQelUyV2VYdWs1QVlSZVZibG9wUUJMS2VWZUJJRlpGWk1ZMGlCRHQK",
      "endpoints": [
        "https://github.com/Zburgers/vibevoice/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
